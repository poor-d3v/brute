# Server Configuration
BRUTE_HOST=0.0.0.0
BRUTE_PORT=5001
BRUTE_DEBUG=false

# CORS Configuration
BRUTE_CORS_ORIGINS=http://localhost:5173

# Python Environment
VIRTUAL_ENV=./venv
BRUTE_PYTHON_PATH=./venv/bin/python3
BRUTE_SITE_PACKAGES=./venv/lib/python3.13/site-packages

# Performance Configuration
BRUTE_CHUNK_SIZE=1000
BRUTE_UPDATE_INTERVAL=1.0 